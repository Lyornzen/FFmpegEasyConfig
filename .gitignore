.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# ---------- Environment ----------
.env
.env.local
.env.*.local

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Temporary ----------
*.tmp
*.temp
.cache/

# ---------- OS packaging artifacts ----------
*.dmg
*.pkg
*.AppImage
*.snap
