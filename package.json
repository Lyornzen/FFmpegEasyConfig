{
  "name": "ffmpeg-gui",
  "version": "1.0.0",
  "description": "跨平台 FFmpeg 桌面 GUI — 视频/音频处理一站式工具",
  "main": "main.js",
  "author": "FFmpeg-GUI",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:win": ".\\node_modules\\electron\\dist\\electron.exe .",
    "start:direct": "node ./node_modules/electron/cli.js .",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ffmpeg-gui.app",
    "productName": "FFmpeg GUI",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**",
      "!node_modules/**",
      "node_modules/@ffmpeg-installer/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Video"
    }
  }
}
