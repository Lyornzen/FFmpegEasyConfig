{
  "name": "ffmpeg-easy-config",
  "version": "1.1.0",
  "description": "FFmpegEasyConfig — A modern desktop FFmpeg GUI built with Electron, React, TypeScript and Ant Design",
  "author": "FFmpegEasyConfig Team",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "package": "tsc && vite build && electron-builder --win",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "antd": "^5.13.0",
    "@ant-design/icons": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.ffmpegeasyconfig.app",
    "productName": "FFmpegEasyConfig",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/icon.png"
    ],
    "icon": "public/icon.png",
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "sign": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.png",
      "uninstallerIcon": "public/icon.png",
      "installerHeaderIcon": "public/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FFmpegEasyConfig"
    },
    "portable": {
      "artifactName": "FFmpegEasyConfig-Portable-${version}.exe"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
